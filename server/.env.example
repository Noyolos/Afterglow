GEMINI_API_KEY=

# Optional base model for all endpoints.
GEMINI_MODEL=gemini-2.5-flash

# Optional per-feature overrides.
GEMINI_ANALYZE_MODEL=gemini-2.5-flash-lite
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_DIARY_MODEL=gemini-2.5-flash

# Set to 0 to disable automatic Google Search grounding for factual chat.
GEMINI_CHAT_USE_SEARCH=1

# Optional: reverse-image style web lookup for famous IP / artwork images.
# Requires Google Cloud Vision + Application Default Credentials.
GOOGLE_VISION_WEB_DETECTION=0
GOOGLE_VISION_LOOKUP_TIMEOUT_MS=1200
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

PORT=8787
